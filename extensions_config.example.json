{
  "mcpServers": {
    "network-ops": {
      "enabled": false,
      "type": "stdio",
      "command": "/app/backend/.venv/bin/python",
      "args": ["/app/mcp-servers/network-ops/server.py"],
      "env": {
        "MYSQL_HOST": "host.docker.internal",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "$MYSQL_USER",
        "MYSQL_PASSWORD": "$MYSQL_PASSWORD",
        "MYSQL_DATABASE": "$MYSQL_DATABASE",
        "BANDWIDTH_MD_PATH": "docs/bandwidth.md",
        "SQLITE_DB_PATH": ".deer-flow/db/network_ops.db",
        "CHROMA_PERSIST_DIR": ".deer-flow/vectors/bandwidth_policy",
        "OLLAMA_BASE_URL": "http://host.docker.internal:11434"
      },
      "description": "网络运维工具集：线路查询、带宽评估、统计查询、邮件生成"
    },
    "ops-knowledge": {
      "enabled": false,
      "type": "stdio",
      "command": "/app/backend/.venv/bin/python",
      "args": ["/app/mcp-servers/ops-knowledge/server.py"],
      "env": {
        "OPS_KNOWLEDGE_DB_PATH": ".deer-flow/db/ops_knowledge.db",
        "CHROMA_PERSIST_DIR": ".deer-flow/vectors/ops_knowledge",
        "OLLAMA_BASE_URL": "http://host.docker.internal:11434"
      },
      "description": "运维知识库工具集：文档入库、语义检索、知识浏览"
    },
    "filesystem": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/path/to/allowed/files"
      ],
      "env": {},
      "description": "Provides filesystem access within allowed directories"
    },
    "github": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "description": "GitHub MCP server for repository operations"
    },
    "postgres": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ],
      "env": {},
      "description": "PostgreSQL database access"
    }
  },
  "skills": {}
}